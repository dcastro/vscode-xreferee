{
  "name": "xreferee",
  "displayName": "xreferee",
  "publisher": "dcastro",
  "description": "Validate cross references throughout a git repo.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcastro/vscode-xreferee.git"
  },
  "bugs": {
    "url": "https://github.com/dcastro/vscode-xreferee/issues"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "xreferee",
      "properties": {
        "xreferee.serverArgs": {
          "type": "string",
          "default": "",
          "description": "Additional command-line arguments passed to the xreferee language server process (for example: --log-file <file>).",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "extract-zip": "^2.0.1",
    "string-argv": "^0.3.2",
    "tar": "^7.5.13",
    "vscode-languageclient": "^8.1.0"
  }
}
